{
  "agis_version": "0.3.0",
  "name": "offline-suspended-agent-verification",
  "description": "Composite offline AgIS verification with a suspended agent — must produce decision=deny and reasonCode=AGENT_SUSPENDED.",
  "input": {
    "dns_txt": "../dns/valid-dns-binding.txt",
    "signed_agent_card": "../agent-card/signed-agent-card.json",
    "status": "../status/suspended-status.json"
  },
  "expected": {
    "validIdentity": true,
    "active": false,
    "revoked": false,
    "trustLevel": 4,
    "decision": "deny",
    "reasonCode": "AGENT_SUSPENDED",
    "checks": {
      "dnsBinding": true,
      "agentCardHash": true,
      "jwkThumbprint": true,
      "agentCardSignature": true,
      "status": true
    }
  }
}
