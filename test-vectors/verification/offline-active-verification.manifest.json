{
  "agis_version": "0.2.2",
  "name": "offline-active-agent-verification",
  "description": "Composite offline AgIS verification using DNS binding, signed Agent Card, JWK thumbprint, Agent Card hash, and active status.",
  "input": {
    "dns_txt": "../dns/valid-dns-binding.txt",
    "signed_agent_card": "../agent-card/signed-agent-card.json",
    "status": "../status/active-status.json"
  },
  "expected": {
    "validIdentity": true,
    "active": true,
    "revoked": false,
    "trustLevel": 4,
    "decision": "allow",
    "checks": {
      "dnsBinding": true,
      "agentCardHash": true,
      "jwkThumbprint": true,
      "agentCardSignature": true,
      "status": true
    }
  }
}
